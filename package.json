    "@types/node": "^20.10.6",
    "tailwindcss": "^3.4.1",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.32",
    "next-auth": "^5.0.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.1.2",
    "prisma": "^5.8.0",
    "@prisma/client": "^5.8.0",
